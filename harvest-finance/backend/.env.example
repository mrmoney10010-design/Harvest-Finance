# Application
PORT=5000

# Database (TypeORM + PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=harvest_finance

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379

# Authentication
JWT_SECRET=super_secret_jwt_key
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=super_secret_refresh_jwt_key
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# IPFS Configuration
IPFS_HOST=localhost
IPFS_PORT=5001
IPFS_PROTOCOL=http

# Delivery Verification
GPS_VALIDATION_RADIUS_METERS=100

# Payment Configuration
PAYMENT_AUTO_RELEASE=true

# Stellar Network
STELLAR_NETWORK=testnet
STELLAR_PLATFORM_PUBLIC_KEY=
STELLAR_PLATFORM_SECRET_KEY=

# Stellar Authentication (SEP-10)
STELLAR_SERVER_SECRET=SBX7SARQOFS6IM2HS2N5TVK54AEF55E3FHOXBTWA6IPEEJJ4W5WJWE6W
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban Event Indexer
SOROBAN_INDEXER_ENABLED=false
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_INDEXER_PAGE_SIZE=100
SOROBAN_INDEXER_BOOTSTRAP_LEDGERS=120
# Optional: comma-separated list of contract IDs to filter; leave empty for all.
SOROBAN_INDEXER_CONTRACT_IDS=

# Secrets Management
# PROVIDER: env (default), aws, vault
SECRETS_PROVIDER=env

# AWS Secrets Manager Configuration
AWS_REGION=us-east-1
# Mapping of keys to AWS Secret IDs (optional, defaults to key name)
# AWS_SECRET_ID_STELLAR_PLATFORM_SECRET_KEY=harvest/stellar-platform-secret

# HashiCorp Vault Configuration
VAULT_URL=http://localhost:8200
VAULT_TOKEN=
VAULT_SECRET_PATH=secret/data/harvest-finance
